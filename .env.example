# ─────────────────────────────────────────────────────────────
# Lobbydots — variables de entorno (plantilla). Copia a .env y rellena.
# NUNCA comitear el .env real. El pepper y el service_role jamás van al bundle móvil.
# ─────────────────────────────────────────────────────────────

# ── Supabase (proyecto hosted: dev / prod) ──
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...            # clave pública (cliente móvil, solo auth)
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # SOLO servidor (NestJS). Exenta de RLS.
SUPABASE_JWT_SECRET=...             # para verificar JWT (o usar el JWKS endpoint)
SUPABASE_PROJECT_REF=YOUR_REF

# ── Postgres (Prisma en NestJS) ──
# Pooler (PgBouncer, transaction mode) para runtime:
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# Conexión directa para migraciones / introspección:
DIRECT_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Hashing (servidor) ──
# Pepper secreto para HMAC-SHA256 de teléfonos. Longevo (rotarlo invalida los hashes).
HASH_PEPPER=GENERA_UN_SECRETO_LARGO_ALEATORIO

# ── API ──
API_PORT=3000
# Origen público de los enlaces de invitación (Universal/App Links):
PUBLIC_APP_URL=https://lobbydots.app

# ── Twilio (proveedor SMS de Supabase Auth; se configura en el dashboard de Supabase) ──
# Documentado aquí como referencia; Supabase los guarda en su panel.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGE_SERVICE_SID=

# ── Móvil (Expo) — prefijo EXPO_PUBLIC_ para exponer al cliente ──
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Web (Next.js) — prefijo NEXT_PUBLIC_ para exponer al navegador ──
# Valores reales en apps/web/.env.local (gitignored). Mismas claves públicas que
# el móvil. NUNCA exponer service_role ni HASH_PEPPER vía NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:3000
